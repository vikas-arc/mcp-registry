# Jira + Confluence Server / Data Center.
# Prefer a READ-ONLY service account here; users' own tokens (forwarded by the
# registry when the catalog entry has forward_auth=true) take precedence for writes.
#
# Pick ONE auth method per product. The server auto-detects: a *_PERSONAL_TOKEN
# (PAT) is used if set; otherwise *_USERNAME + *_API_TOKEN (basic auth).

JIRA_URL=https://jira.yourco.com
CONFLUENCE_URL=https://confluence.yourco.com

# --- Option A: Personal Access Token (recommended) ---
JIRA_PERSONAL_TOKEN=
CONFLUENCE_PERSONAL_TOKEN=

# --- Option B: username + password (basic auth) ---
# For Server/DC, put your PASSWORD in *_API_TOKEN (the field doubles as the password).
# Leave the *_PERSONAL_TOKEN lines above blank if you use this.
# JIRA_USERNAME=
# JIRA_API_TOKEN=            # your Jira password
# CONFLUENCE_USERNAME=
# CONFLUENCE_API_TOKEN=      # your Confluence password

# Port this server listens on (registry catalogs http://127.0.0.1:$ATL_PORT/mcp)
ATL_PORT=9004

# Uncomment for self-signed / internal CA certs:
# JIRA_SSL_VERIFY=false
# CONFLUENCE_SSL_VERIFY=false
