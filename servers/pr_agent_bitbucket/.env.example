# PR-Agent (Bitbucket Server / Data Center)
BITBUCKET_SERVER_URL=https://bitbucket.yourco.com
OPENAI_KEY=                      # OpenAI API key
PR_AGENT_MODEL=gpt-4o            # optional

# --- Auth: pick ONE ---
# Option A: HTTP access token (recommended; required for git-clone operations)
BITBUCKET_SERVER_TOKEN=

# Option B: username + password (basic auth) — leave the token blank to use this
# BITBUCKET_SERVER_USERNAME=
# BITBUCKET_SERVER_PASSWORD=
